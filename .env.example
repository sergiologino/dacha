# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/dacha_db?schema=public"

# NextAuth (также используется для return_url после оплаты ЮKassa — на продакшене обязательно ваш домен)
NEXTAUTH_URL="https://dacha-ai.ru"
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_YANDEX_ID=""
AUTH_YANDEX_SECRET=""
# Временно держим вход по SMS скрытым до оформления договора с провайдером
# NEXT_PUBLIC_ENABLE_PHONE_AUTH="0"
SMS_RU_API_ID=""
# SMS_RU_FROM=""
# SMS_RU_TEST="0"

# YandexGPT (server-side only)
YANDEX_API_KEY=""
YANDEX_FOLDER_ID=""

# YooKassa payments
YOOKASSA_SHOP_ID=""
YOOKASSA_SECRET_KEY=""

# AI Integration Service (server-side only)
AI_INTEGRATION_URL=""
AI_INTEGRATION_API_KEY=""

# Admin emails (comma-separated, for premium toggle)
ADMIN_EMAILS="your@email.com"

# Analytics (leave empty to disable)
NEXT_PUBLIC_YM_ID=""
NEXT_PUBLIC_GA_ID=""

# Yandex Webmaster verification (meta name="yandex-verification" content="...")
# Default 57dacdee3aae7bf0 is used if empty
NEXT_PUBLIC_YANDEX_VERIFICATION="57dacdee3aae7bf0"

# Optional: App URL for share links (defaults to NEXTAUTH_URL)
# NEXT_PUBLIC_APP_URL="https://dacha-ai.ru"

# Push notifications (generate: npx web-push generate-vapid-keys)
# VAPID_PUBLIC_KEY=""
# VAPID_PRIVATE_KEY=""

# Cron: secret for /api/cron/push-reminders (daily reminders; call with ?secret=... or Authorization: Bearer <CRON_SECRET>)
# CRON_SECRET=""
