generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth (NextAuth compatible) ─────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  region        String    @default("Москва")
  latitude      Float?
  longitude     Float?
  locationName  String?
  regionReport  String?
  onboardingDone Boolean  @default(false)
  isPremium     Boolean   @default(false)
  premiumUntil  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  plants       Plant[]
  beds         Bed[]
  analyses     Analysis[]
  photos       Photo[]
  tasks        TaskQueue[]
  chatMessages ChatMessage[]
  payments     Payment[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Garden domain ──────────────────────────────────────────

model Crop {
  id            Int      @id @default(autoincrement())
  name          String
  slug          String   @unique
  category      String
  description   String?
  plantMonths   String[]
  harvestMonths String[]
  waterSchedule String?
  difficulty    Int      @default(1) // 1-5
  regions       String[]
  careNotes     String?
  imageUrl      String?
  varieties     Json?    // [{ name, desc }] — сорта для культур, добавленных дачниками
  createdAt     DateTime @default(now())

  plants Plant[]

  @@map("crops")
}

model Bed {
  id        String   @id @default(cuid())
  userId    String
  name      String
  number    String?
  type      String   @default("open") // open, greenhouse, raised
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  plants Plant[]
  photos Photo[]

  @@map("beds")
}

model Plant {
  id          String    @id @default(cuid())
  userId      String
  cropId      Int?
  cropSlug    String?   // slug из справочника для ссылки на /guide/[slug]
  bedId       String?
  name        String
  plantedDate DateTime  @default(now())
  harvestDate DateTime?
  notes       String?
  status      String    @default("growing") // growing, harvested, dead
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  syncedAt    DateTime?

  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  crop          Crop?                @relation(fields: [cropId], references: [id])
  bed           Bed?                 @relation(fields: [bedId], references: [id])
  photos        Photo[]
  analyses      Analysis[]
  timelineEvents PlantTimelineEvent[]

  @@map("plants")
}

model PlantTimelineEvent {
  id            String    @id @default(cuid())
  plantId       String
  plant         Plant     @relation(fields: [plantId], references: [id], onDelete: Cascade)
  type         String    // sprout, transplant, water, loosen, light_temp, feed, pinch, harvest, other
  title        String
  description  String?
  scheduledDate DateTime
  dateTo       DateTime?
  isAction     Boolean   @default(true)
  sortOrder    Int       @default(0)
  doneAt       DateTime?
  createdAt    DateTime  @default(now())
  isUserCreated Boolean  @default(false) // true — добавлено пользователем вручную; false — сгенерировано ИИ

  @@index([plantId])
  @@map("plant_timeline_events")
}

model Photo {
  id             String    @id @default(cuid())
  userId         String
  plantId        String?
  bedId         String?
  url            String
  caption        String?
  isPublic       Boolean   @default(false)
  takenAt        DateTime  @default(now())
  createdAt      DateTime  @default(now())
  syncedAt       DateTime?
  analysisResult String?   // вердикт нейросети по состоянию растения на фото
  analysisStatus String?   // ok | problem — для точки на таймлайне (синяя/красная)
  analyzedAt     DateTime? // когда выполнен анализ

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  plant Plant? @relation(fields: [plantId], references: [id], onDelete: SetNull)
  bed   Bed?   @relation(fields: [bedId], references: [id], onDelete: SetNull)

  @@map("photos")
}

model Analysis {
  id        String   @id @default(cuid())
  userId    String
  plantId   String?
  imageUrl  String
  result    String
  status    String   @default("completed") // pending, completed, failed
  isViewed  Boolean  @default(false)
  createdAt DateTime @default(now())
  syncedAt  DateTime?

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  plant Plant? @relation(fields: [plantId], references: [id], onDelete: SetNull)

  @@map("analyses")
}

// ─── Chat messages (persisted) ───────────────────────────────

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  role      String   // user | assistant
  content   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("chat_messages")
}

// ─── Shared content (public links) ──────────────────────────

model SharedContent {
  id        String   @id @default(cuid())
  type      String   // chat | analysis
  data      Json
  createdAt DateTime @default(now())

  @@map("shared_content")
}

// ─── AI-generated crop guides (cached) ──────────────────────

model CropGuide {
  id        String   @id @default(cuid())
  cropSlug  String   @unique
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("crop_guides")
}

// ─── Offline sync ───────────────────────────────────────────

model TaskQueue {
  id          String   @id @default(cuid())
  userId      String
  action      String   // create_plant, update_plant, delete_plant, analyze_photo, etc.
  payload     Json
  status      String   @default("pending") // pending, processing, completed, failed
  retries     Int      @default(0)
  errorMsg    String?
  createdAt   DateTime @default(now())
  processedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("task_queue")
}

// ─── AI prompts (редактируемые в БД) ────────────────────────

model Prompt {
  id          String   @id @default(cuid())
  key         String   @unique // slug для выбора в коде: chat_system, vision_system, ...
  prompt      String   @db.Text
  description String
  endpoint    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("prompts")
}

// ─── Логи вызовов нейросетей (мониторинг расходов) ──────────

model AiCallLog {
  id             String   @id @default(cuid())
  userId         String?  // опционально (guide-generator и т.п. без пользователя)
  createdAt      DateTime @default(now())
  endpoint       String   // наш роут: /api/chat, /api/ai/analyze, ...
  requestType    String   // chat | vision | image_gen
  messages       Json?    // сводка: роли и длины/превью сообщений
  responsePreview String?
  tokensInput    Int?
  tokensOutput   Int?
  tokensTotal    Int?
  status         String
  errorMessage   String?

  @@index([userId, createdAt])
  @@index([endpoint, createdAt])
  @@map("ai_call_logs")
}

// ─── Payments ───────────────────────────────────────────────

model Payment {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  yookassaId    String?  @unique
  amount        Int
  currency      String   @default("RUB")
  status        String   @default("pending") // pending, succeeded, canceled
  plan          String   // monthly, yearly
  description   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@map("payments")
}
